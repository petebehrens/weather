{
  "manifest_version": 3,
  "name": "Weather",
  "version": "0.1.0",
  "description": "Quiet weather for cycling — Louisville, Winter Park, LA. NOAA data, no ads.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Weather",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
